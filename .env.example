# Internal SQLite database
DATABASE_URL=file:./data/rexadb.db

# Encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-to-a-64-char-hex-key

# Supabase Auth (only needed if using default auth adapter)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Studio JWT Secret (for authenticating users from main app)
STUDIO_JWT_SECRET=change-me-to-a-32-char-hex-secret

# Server
PORT=3000