# Internal SQLite database
DATABASE_URL=file:./data/rexadb.db

# Encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-to-a-64-char-hex-key

# Studio JWT Secret (for authenticating users from main app)
STUDIO_JWT_SECRET=change-me-to-a-64-char-hex-secret

# Server
PORT=3000

# Optional: path for JSONL audit log file (defaults to ./data/audit-logs.jsonl)
# AUDIT_LOG_FILE=./data/audit-logs.jsonl

# Studio instance name (defaults to hostname-based name, persisted in data/studio.json)
# STUDIO_NAME=My Studio